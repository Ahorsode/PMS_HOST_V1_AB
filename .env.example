# Database (Supabase)
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# NextAuth
AUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Upstash Redis (for rate limiting)
UPSTASH_REDIS_REST_URL="https://your-upstash-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Admin panel
HATCHLOG_ADMIN_SESSION_SECRET="your-admin-secret-min-32-chars"

# Sentry (optional)
SENTRY_DSN="https://your-private-sentry-dsn@sentry.io/project"
NEXT_PUBLIC_SENTRY_DSN="https://your-public-sentry-dsn@sentry.io/project"
SENTRY_AUTH_TOKEN="your-sentry-auth-token-for-source-map-uploads"
