generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String            @id @default(cuid())
  firstname          String?
  surname            String?
  email              String?           @unique
  emailVerified      DateTime?         @map("email_verified")
  image              String?
  role               Role              @default(OWNER)
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  name               String?
  phoneNumber        String?           @unique @map("phone_number")
  middleName         String?           @map("middle_name")
  password           String?
  mustChangePassword Boolean           @default(false) @map("must_change_password")
  accounts           Account[]
  auditLogs          AuditLog[]
  batches            Livestock[]
  feedingLogs        FeedingLog[]
  deleteLogs         DeleteLog[]
  eggProductions     EggProduction[]
  expenses           Expense[]
  memberships        FarmMember[]
  farms              Farm[]
  insertLogs         InsertLog[]
  inventory          Inventory[]
  mortalities        HealthMortality[]
  orders             Order[]
  sales              Sale[]
  sessions           Session[]
  userPermissions    UserPermission[]
  weightRecords      WeightRecord[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  deviceType   String?  @map("device_type")
  farmId       String?  @map("farm_id")
  loginTime    DateTime @default(now()) @map("login_time")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Farm {
  id               String                @id @default(cuid())
  name             String
  location         String?
  capacity         Int
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  userId           String                @default("user_placeholder")
  subscriptionTier SubscriptionTier      @default(BASIC)
  batches          Livestock[]
  customers        Customer[]
  feedingLogs      FeedingLog[]
  eggCategories    EggCategory[]
  eggProduction    EggProduction[]
  expenses         Expense[]
  members          FarmMember[]
  settings         FarmSettings?
  user             User                  @relation(fields: [userId], references: [id])
  feedFormulations FeedFormulation[]
  healthRecords    HealthRecord[]
  houses           House[]
  inventory        Inventory[]
  invitations      Invitation[]
  isolationRooms   IsolationRoom[]
  medications      MedicationSchedule[]
  mortality        HealthMortality[]
  orders           Order[]
  saleItems        SaleItem[]
  sales            Sale[]
  subscription     Subscription?
  suppliers        Supplier[]
  userPermissions  UserPermission[]
  vaccinations        VaccinationSchedule[]
  weightRecords       WeightRecord[]
  deviceRegistrations DeviceRegistration[]

  @@index([userId])
  @@map("farms")
}

model House {
  id                 String      @id @default(cuid())
  farmId             String
  name               String
  capacity           Int
  currentTemperature Decimal?    @db.Decimal(5, 2)
  currentHumidity    Decimal?    @db.Decimal(5, 2)
  userId             String      @default("user_placeholder")
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  isIsolation        Boolean     @default(false)
  batches            Livestock[]
  farm               Farm        @relation(fields: [farmId], references: [id])

  @@index([userId])
  @@index([farmId])
  @@map("houses")
}

model Livestock {
  id                   String                @id @default(cuid())
  status               String                @default("active")
  arrivalDate          DateTime
  breedType            String
  createdAt            DateTime              @default(now())
  currentCount         Int
  houseId              String
  initialCount         Int
  updatedAt            DateTime              @updatedAt
  userId               String                @default("user_placeholder")
  farmId               String                @default("farm_placeholder")
  batchName            String                @default("New Batch")
  carriage_inward      Decimal?              @db.Decimal(15, 2)
  growthTargetOverride String?
  growth_target        String?
  initialCostActual    Decimal?              @db.Decimal(15, 2)
  initialCostCarriage  Decimal?              @db.Decimal(15, 2)
  initialCostOther     Json?
  initial_actual_cost  Decimal?              @db.Decimal(15, 2)
  initial_other_costs  Json?
  isolationCount       Int                   @default(0)
  type                 LivestockType         @default(POULTRY_BROILER)
  localBatchId         Int?                  @map("local_batch_id")
  farm                 Farm                  @relation(fields: [farmId], references: [id])
  house                House                 @relation(fields: [houseId], references: [id])
  user                 User                  @relation(fields: [userId], references: [id])
  mortalityRecords     HealthMortality[]
  feedingLogs          FeedingLog[]
  eggProduction        EggProduction[]
  expenses             Expense[]
  healthRecords        HealthRecord[]
  medications          MedicationSchedule[]
  orderItems           OrderItem[]
  vaccinations         VaccinationSchedule[]
  weightRecords        WeightRecord[]

  @@index([status])
  @@index([type])
  @@index([userId])
  @@index([farmId])
  @@map("batches")
}

model Inventory {
  id                         String                      @id @default(cuid())
  itemName                   String
  stockLevel                 Decimal                     @db.Decimal(15, 2)
  unit                       String
  category                   String?
  userId                     String                      @default("user_placeholder")
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  farmId                     String                      @default("farm_placeholder")
  reorderLevel               Decimal?                    @default(500.00) @db.Decimal(15, 2)
  costPerUnit                Decimal?                    @db.Decimal(15, 2)
  eggCategoryId              String?
  supplierId                 String?
  feedingLogs                FeedingLog[]
  feedFormulationIngredients FeedFormulationIngredient[]
  eggCategory                EggCategory?                @relation(fields: [eggCategoryId], references: [id])
  farm                       Farm                        @relation(fields: [farmId], references: [id])
  supplier                   Supplier?                   @relation(fields: [supplierId], references: [id])
  user                       User                        @relation(fields: [userId], references: [id])
  orderItems                 OrderItem[]

  @@index([userId])
  @@index([farmId])
  @@map("inventory")
}

model InsertLog {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  farmId      String   @map("farm_id")
  targetTable String   @map("target_table")
  recordId    String   @map("record_id")
  insertedAt  DateTime @default(now()) @map("inserted_at")
  user        User     @relation(fields: [userId], references: [id])

  @@map("insert_logs")
}

model DeleteLog {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  farmId         String   @map("farm_id")
  tableName      String   @map("table_name")
  deletedDataCsv String   @map("deleted_data_csv")
  deletedAt      DateTime @default(now()) @map("deleted_at")
  user           User     @relation(fields: [userId], references: [id])

  @@map("delete_logs")
}

model FeedingLog {
  id             String           @id @default(cuid())
  batchId        String?          @map("batch_id")
  feedTypeId     String?          @map("feed_type_id")
  amountConsumed Decimal          @map("amount_consumed") @db.Decimal(15, 2)
  logDate        DateTime         @default(now()) @map("log_date")
  userId         String?          @map("user_id")
  farmId         String           @default("farm_placeholder")
  formulationId  String?          @map("formulation_id")
  batch          Livestock?       @relation(fields: [batchId], references: [id])
  farm           Farm             @relation(fields: [farmId], references: [id])
  inventory      Inventory?       @relation(fields: [feedTypeId], references: [id])
  formulation    FeedFormulation? @relation(fields: [formulationId], references: [id])
  user           User?            @relation(fields: [userId], references: [id])

  @@index([batchId, logDate])
  @@index([userId])
  @@index([farmId])
  @@map("daily_feeding_logs")
}

model HealthRecord {
  id          String     @id @default(cuid())
  batchId     String?    @map("batch_id")
  recordType  String?    @map("record_type") @db.VarChar(50)
  description String?
  recordDate  DateTime   @default(now()) @map("record_date") @db.Date
  farmId      String     @default("farm_placeholder")
  batch       Livestock? @relation(fields: [batchId], references: [id])
  farm        Farm       @relation(fields: [farmId], references: [id])

  @@index([farmId])
  @@map("health_records")
}

model EggProduction {
  id              String       @id @default(cuid())
  batchId         String
  eggsCollected   Int
  logDate         DateTime
  userId          String       @default("user_placeholder")
  createdAt       DateTime     @default(now())
  farmId          String       @default("farm_placeholder")
  categoryId      String?
  cratesCollected Decimal?     @db.Decimal(15, 2)
  eggsRemaining   Int          @default(0)
  qualityGrade    String?
  unusableCount   Int          @default(0)
  isSorted        Boolean      @default(false)
  smallCount      Int          @default(0)
  mediumCount     Int          @default(0)
  largeCount      Int          @default(0)
  batch           Livestock    @relation(fields: [batchId], references: [id])
  category        EggCategory? @relation(fields: [categoryId], references: [id])
  farm            Farm         @relation(fields: [farmId], references: [id])
  user            User         @relation(fields: [userId], references: [id])

  @@index([batchId, logDate])
  @@index([userId])
  @@index([farmId])
  @@map("egg_production")
}

model IsolationRoom {
  id        String            @id @default(cuid())
  farmId    String
  name      String
  capacity  Int
  userId    String            @default("user_placeholder")
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  farm      Farm              @relation(fields: [farmId], references: [id])
  records   HealthMortality[]

  @@index([farmId])
  @@index([userId])
  @@map("isolation_rooms")
}

model HealthMortality {
  id              String          @id @default(cuid())
  batchId         String
  count           Int
  reason          String?
  logDate         DateTime
  userId          String          @default("user_placeholder")
  createdAt       DateTime        @default(now())
  category        String?
  farmId          String          @default("farm_placeholder")
  subCategory     String?         @map("sub_category")
  isolationRoomId String?         @map("isolation_room_id")
  type            HealthEventType @default(DEAD)
  batch           Livestock       @relation(fields: [batchId], references: [id])
  farm            Farm            @relation(fields: [farmId], references: [id])
  isolationRoom   IsolationRoom?  @relation(fields: [isolationRoomId], references: [id])
  user            User            @relation(fields: [userId], references: [id])

  @@index([batchId, logDate])
  @@index([userId])
  @@index([farmId])
  @@map("mortality")
}

model WeightRecord {
  id            String    @id @default(cuid())
  batchId       String
  averageWeight Decimal   @db.Decimal(10, 3)
  logDate       DateTime
  userId        String    @default("user_placeholder")
  farmId        String    @default("farm_placeholder")
  createdAt     DateTime  @default(now())
  batch         Livestock @relation(fields: [batchId], references: [id])
  farm          Farm      @relation(fields: [farmId], references: [id])
  user          User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([farmId])
  @@map("weight_records")
}

model Sale {
  id           String     @id @default(cuid())
  customerName String?
  totalAmount  Decimal    @db.Decimal(15, 2)
  saleDate     DateTime   @default(now())
  status       String     @default("completed")
  userId       String     @default("user_placeholder")
  createdAt    DateTime   @default(now())
  farmId       String     @default("farm_placeholder")
  items        SaleItem[]
  farm         Farm       @relation(fields: [farmId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@index([saleDate, status])
  @@index([userId])
  @@index([farmId])
  @@map("sales")
}

model SaleItem {
  id          String  @id @default(cuid())
  saleId      String
  description String
  quantity    Int
  unitPrice   Decimal @db.Decimal(15, 2)
  totalPrice  Decimal @db.Decimal(15, 2)
  farmId      String  @default("farm_placeholder")
  farm        Farm    @relation(fields: [farmId], references: [id])
  sale        Sale    @relation(fields: [saleId], references: [id])

  @@index([farmId])
  @@map("sale_items")
}

model FarmMember {
  id        String   @id @default(cuid())
  farmId    String
  userId    String
  role      Role     @default(WORKER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  farm      Farm     @relation(fields: [farmId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([farmId, userId])
  @@map("farm_members")
}

model Invitation {
  id          String   @id @default(cuid())
  email       String?
  role        Role     @default(WORKER)
  status      String   @default("PENDING")
  createdAt   DateTime @default(now()) @map("created_at")
  farmId      String   @map("farm_id")
  phoneNumber String?  @unique @map("phone_number")
  updatedAt   DateTime @updatedAt @map("updated_at")
  farm        Farm     @relation(fields: [farmId], references: [id])

  @@unique([email, farmId])
  @@index([farmId])
  @@map("invitations")
}

model VaccinationSchedule {
  id            String    @id @default(cuid())
  batchId       String
  vaccineName   String
  scheduledDate DateTime
  status        String    @default("PENDING")
  notes         String?
  farmId        String    @default("farm_placeholder")
  batch         Livestock @relation(fields: [batchId], references: [id], onDelete: Cascade)
  farm          Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([farmId])
  @@map("vaccination_schedules")
}

model MedicationSchedule {
  id             String    @id @default(cuid())
  batchId        String
  medicationName String
  scheduledDate  DateTime
  status         String    @default("PENDING")
  notes          String?
  farmId         String    @default("farm_placeholder")
  batch          Livestock @relation(fields: [batchId], references: [id], onDelete: Cascade)
  farm           Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([farmId])
  @@map("medication_schedules")
}

model FarmSettings {
  id                     String   @id @default(cuid())
  farmId                 String   @unique
  eggRecordReminderTime  String?  @default("18:00")
  feedRecordReminderTime String?  @default("18:00")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  currency               String   @default("GHS")
  growthTargetStandard   Int?     @map("growth_target_standard")
  eggsPerCrate           Int      @default(30)
  farm                   Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@map("farm_settings")
}

model AuditLog {
  id            String   @id @default(cuid())
  tableName     String   @map("table_name")
  recordId      String   @map("record_id")
  attributeName String   @map("attribute_name")
  oldValue      String?  @map("old_value")
  newValue      String?  @map("new_value")
  reason        String?
  userId        String   @map("user_id")
  farmId        String   @map("farm_id")
  createdAt     DateTime @default(now()) @map("created_at")
  user          User     @relation(fields: [userId], references: [id])

  @@index([farmId])
  @@index([userId])
  @@map("audit_logs")
}

model Expense {
  id          String          @id @default(cuid())
  farmId      String
  userId      String          @map("user_id")
  amount      Decimal         @db.Decimal(15, 2)
  category    ExpenseCategory
  description String?
  expenseDate DateTime        @default(now()) @map("expense_date")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  batch_id    String?
  supplierId  String?
  batches     Livestock?      @relation(fields: [batch_id], references: [id])
  farm        Farm            @relation(fields: [farmId], references: [id], onDelete: Cascade)
  supplier    Supplier?       @relation(fields: [supplierId], references: [id])
  user        User            @relation(fields: [userId], references: [id])

  @@index([expenseDate, category])
  @@index([farmId])
  @@index([userId])
  @@index([batch_id])
  @@map("expenses")
}

model UserPermission {
  id               String  @id @default(cuid())
  userId           String  @map("user_id")
  farmId           String  @map("farm_id")
  canViewFinance   Boolean @default(false) @map("can_view_finance")
  canEditFinance   Boolean @default(false) @map("can_edit_finance")
  canViewInventory Boolean @default(false) @map("can_view_inventory")
  canEditInventory Boolean @default(false) @map("can_edit_inventory")
  canViewBatches   Boolean @default(false) @map("can_view_batches")
  canEditBatches   Boolean @default(false) @map("can_edit_batches")
  canViewSales     Boolean @default(false) @map("can_view_sales")
  canEditSales     Boolean @default(false) @map("can_edit_sales")
  canViewEggs      Boolean @default(false) @map("can_view_eggs")
  canEditEggs      Boolean @default(false) @map("can_edit_eggs")
  canViewFeeding   Boolean @default(false) @map("can_view_feeding")
  canEditFeeding   Boolean @default(false) @map("can_edit_feeding")
  canViewHouses    Boolean @default(false) @map("can_view_houses")
  canEditHouses    Boolean @default(false) @map("can_edit_houses")
  canViewMortality Boolean @default(false) @map("can_view_mortality")
  canEditMortality Boolean @default(false) @map("can_edit_mortality")
  canViewCustomers Boolean @default(false) @map("can_view_customers")
  canEditCustomers Boolean @default(false) @map("can_edit_customers")
  canViewTeam      Boolean @default(false) @map("can_view_team")
  canEditTeam      Boolean @default(false) @map("can_edit_team")
  farm             Farm    @relation(fields: [farmId], references: [id], onDelete: Cascade)
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, farmId])
  @@index([farmId])
  @@index([userId])
  @@map("user_permissions")
}

model GrowthStandards {
  id            String        @id @default(cuid())
  livestockType LivestockType
  ageInDays     Int
  targetWeight  Decimal       @db.Decimal(10, 3)
  targetFeed    Decimal?      @db.Decimal(10, 3)
  unit          String        @default("kg")
  createdAt     DateTime      @default(now())

  @@map("growth_standards")
}

model SubscriptionPlan {
  id            String           @id @default(cuid())
  name          String
  tier          SubscriptionTier
  price         Decimal          @db.Decimal(15, 2)
  currency      String           @default("USD")
  interval      String           @default("monthly")
  features      Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id        String           @id @default(cuid())
  farmId    String           @unique
  planId    String
  status    String           @default("ACTIVE")
  startDate DateTime         @default(now())
  endDate   DateTime?
  farm      Farm             @relation(fields: [farmId], references: [id])
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model Customer {
  id          String   @id @default(cuid())
  farmId      String
  name        String
  phone       String?
  email       String?
  address     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  balanceOwed Decimal  @default(0) @db.Decimal(15, 2)
  farm        Farm     @relation(fields: [farmId], references: [id])
  orders      Order[]

  @@map("customers")
}

model Order {
  id             String      @id @default(cuid())
  farmId         String
  customerId     String?
  totalAmount    Decimal     @db.Decimal(15, 2)
  currency       String      @default("USD")
  status         String      @default("PENDING")
  discountAmount Decimal     @default(0) @db.Decimal(15, 2)
  createdAt      DateTime    @default(now()) @map("created_at")
  orderDate      DateTime    @default(dbgenerated("'2024-01-01 00:00:00'::timestamp without time zone")) @map("order_date")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  userId         String      @default("user_placeholder") @map("user_id")
  items          OrderItem[]
  customer       Customer?   @relation(fields: [customerId], references: [id])
  farm           Farm        @relation(fields: [farmId], references: [id])
  user           User        @relation(fields: [userId], references: [id])

  @@index([orderDate, status])
  @@map("orders")
}

model OrderItem {
  id          String     @id @default(cuid())
  orderId     String
  description String
  quantity    Int
  unitPrice   Decimal    @db.Decimal(15, 2)
  totalPrice  Decimal    @db.Decimal(15, 2)
  inventoryId String?
  livestockId String?
  inventory   Inventory? @relation(fields: [inventoryId], references: [id])
  batch       Livestock? @relation(fields: [livestockId], references: [id])
  order       Order      @relation(fields: [orderId], references: [id])

  @@map("order_items")
}

model FeedFormulation {
  id              String                      @id @default(cuid())
  farmId              String
  name                String
  notes               String?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  targetLivestock     LivestockType?
  type                FeedType
  stockLevel          Decimal                     @default(0) @db.Decimal(10, 2)
  ingredients         FeedFormulationIngredient[]
  feedingLogs         FeedingLog[]
  farm                Farm                        @relation(fields: [farmId], references: [id])

  @@map("feed_formulations")
}

model FeedFormulationIngredient {
  id            String          @id @default(cuid())
  formulationId String
  inventoryId   String
  quantity      Decimal         @db.Decimal(10, 2)
  unit          String
  formulation   FeedFormulation @relation(fields: [formulationId], references: [id])
  inventory     Inventory       @relation(fields: [inventoryId], references: [id])

  @@map("feed_formulation_ingredients")
}

model Supplier {
  id          String      @id @default(cuid())
  farmId      String
  name        String
  phone       String?
  email       String?
  address     String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  farm        Farm        @relation(fields: [farmId], references: [id])
  inventories Inventory[]
  expenses    Expense[]

  @@map("suppliers")
}

model EggCategory {
  id              String          @id @default(cuid())
  farmId          String
  name            String
  description     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  eggProductions  EggProduction[]
  farm            Farm            @relation(fields: [farmId], references: [id])
  inventoryItems  Inventory[]
  sellingPrice    Decimal         @default(0) @db.Decimal(15, 2)
  unitSize        Int             @default(30)
  isStockInternal Boolean         @default(true)

  @@map("egg_categories")
}

enum HealthEventType {
  SICK
  DEAD
}

enum LivestockType {
  POULTRY_BROILER
  POULTRY_LAYER
  CATTLE
  SHEEP_GOAT
  PIG
  OTHER
}

enum Role {
  OWNER
  MANAGER
  WORKER
  ACCOUNTANT
  FINANCE_OFFICER
  CASHIER
}

enum ExpenseCategory {
  FEED
  MEDICATION
  EQUIPMENT
  UTILITIES
  SALARY
  MAINTENANCE
  OTHER
  LIVESTOCK_PURCHASE
  TRANSPORT
}

enum SubscriptionTier {
  BASIC
  STANDARD
  PREMIUM
}

enum FeedType {
  PRE_STARTER
  STARTER
  GROWER
  FINISHER
  BREEDER
  CUSTOM
}

model DeviceRegistration {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  farmId       String   @map("farmId")
  userId       String   @map("userId")
  deviceId     String   @map("deviceId")
  deviceName   String?  @map("deviceName")
  deviceType   String?  @map("deviceType")
  lastSync     DateTime @default(now()) @map("lastSync")
  isActive     Boolean  @default(true) @map("isActive")
  registeredAt DateTime @default(now()) @map("registeredAt")
  farm         Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@unique([farmId, deviceId])
  @@map("device_registrations")
}
