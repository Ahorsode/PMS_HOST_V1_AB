generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String           @id @default(cuid())
  firstname       String?
  surname         String?
  email           String?          @unique
  emailVerified   DateTime?        @map("email_verified")
  image           String?
  role            Role             @default(OWNER)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  name            String?
  middleName      String?          @map("middle_name")
  password        String?
  mustChangePassword Boolean          @default(false) @map("must_change_password")
  phoneNumber     String?          @unique @map("phone_number")
  accounts        Account[]
  batches         Livestock[]
  feedingLogs     FeedingLog[]
  memberships     FarmMember[]
  farms           Farm[]
  sessions        Session[]
  expenses        Expense[]
  userPermissions UserPermission[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Farm {
  id              Int                   @id @default(autoincrement())
  name            String
  location        String?
  capacity        Int
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  userId          String                @default("user_placeholder")
  members         FarmMember[]
  user            User                  @relation(fields: [userId], references: [id])
  houses          House[]
  invitations     Invitation[]
  batches         Livestock[]
  inventory       Inventory[]
  feedingLogs     FeedingLog[]
  healthRecords   HealthRecord[]
  eggProduction   EggProduction[]
  mortality       Mortality[]
  weightRecords   WeightRecord[]
  sales           Sale[]
  saleItems       SaleItem[]
  expenses        Expense[]
  vaccinations    VaccinationSchedule[]
  medications     MedicationSchedule[]
  settings        FarmSettings?
  subscription    Subscription?
  subscriptionTier SubscriptionTier     @default(BASIC)
  customers       Customer[]
  orders          Order[]
  feedFormulations FeedFormulation[]
  userPermissions UserPermission[]

  @@index([userId])
  @@map("farms")
}

model House {
  id                 Int      @id @default(autoincrement())
  farmId             Int
  name               String
  capacity           Int
  currentTemperature Decimal? @db.Decimal(5, 2)
  currentHumidity    Decimal? @db.Decimal(5, 2)
  userId             String   @default("user_placeholder")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  batches            Livestock[]
  farm               Farm     @relation(fields: [farmId], references: [id])

  @@index([userId])
  @@index([farmId])
  @@map("houses")
}

model Livestock {
  id               Int                   @id @default(autoincrement())
  batchName        String                @default("New Batch") // User-Defined Original Name
  type             LivestockType         @default(POULTRY_BROILER)
  status           String                @default("active")
  arrivalDate      DateTime
  breedType        String
  createdAt        DateTime              @default(now())
  currentCount     Int
  houseId          Int
  farmId           Int                   @default(1)
  initialCount     Int
  updatedAt        DateTime              @updatedAt
  userId           String                @default("user_placeholder")
  metadata         Json?                 // Type-specific data (e.g. Batch #, Tag ID)
  initialCostActual    Decimal?          @db.Decimal(10, 2)
  initialCostCarriage  Decimal?          @db.Decimal(10, 2)
  initialCostOther     Json?             // List of { label: string, amount: number }
  growthTargetOverride String?           // e.g. "Ross 308", "Cobb 500"
  
  house            House                 @relation(fields: [houseId], references: [id])
  farm             Farm                  @relation(fields: [farmId], references: [id])
  user             User                  @relation(fields: [userId], references: [id])
  feedingLogs      FeedingLog[]
  eggProduction    EggProduction[]
  healthRecords    HealthRecord[]
  mortalityRecords Mortality[]
  weightRecords    WeightRecord[]
  vaccinations     VaccinationSchedule[]
  medications      MedicationSchedule[]
  orderItems       OrderItem[]

  @@index([userId])
  @@index([farmId])
  @@map("batches")
}

enum LivestockType {
  POULTRY_BROILER
  POULTRY_LAYER
  CATTLE
  SHEEP_GOAT
  PIG
}

model Inventory {
  id           Int          @id @default(autoincrement())
  itemName     String
  stockLevel   Decimal      @db.Decimal(10, 2)
  reorderLevel Decimal?     @default(500.00) @db.Decimal(10, 2)
  unit         String
  category     String?
  userId       String       @default("user_placeholder")
  farmId       Int          @default(1)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  feedingLogs  FeedingLog[]
  feedFormulationIngredients FeedFormulationIngredient[]
  orderItems                 OrderItem[]
  farm                       Farm                        @relation(fields: [farmId], references: [id])

  @@index([userId])
  @@index([farmId])
  @@map("inventory")
}

model FeedingLog {
  id             Int        @id @default(autoincrement())
  batchId        Int?       @map("batch_id")
  feedTypeId     Int?       @map("feed_type_id")
  formulationId  Int?       @map("formulation_id")
  amountConsumed Decimal    @map("amount_consumed") @db.Decimal(10, 2)
  logDate        DateTime   @default(now()) @map("log_date")
  userId         String?    @map("user_id")
  farmId         Int        @default(1)
  
  batch          Livestock?      @relation(fields: [batchId], references: [id])
  inventory      Inventory?      @relation(fields: [feedTypeId], references: [id])
  formulation    FeedFormulation? @relation(fields: [formulationId], references: [id])
  user           User?           @relation(fields: [userId], references: [id])
  farm           Farm            @relation(fields: [farmId], references: [id])

  @@index([userId])
  @@index([farmId])
  @@map("daily_feeding_logs")
}

model HealthRecord {
  id          Int      @id @default(autoincrement())
  batchId     Int?     @map("batch_id")
  recordType  String?  @map("record_type") @db.VarChar(50)
  description String?
  recordDate  DateTime @default(now()) @map("record_date") @db.Date
  farmId      Int      @default(1)
  batch       Livestock?   @relation(fields: [batchId], references: [id])
  farm        Farm     @relation(fields: [farmId], references: [id])

  @@index([farmId])
  @@map("health_records")
}

model EggProduction {
  id            Int      @id @default(autoincrement())
  batchId       Int
  eggsCollected Int
  unusableCount Int      @default(0) // Replacing damaged/cracked with broader unusable
  qualityGrade  String?  // A, B, C or Premium, Standard, etc
  logDate       DateTime
  userId        String   @default("user_placeholder")
  farmId        Int      @default(1)
  createdAt     DateTime @default(now())
  batch         Livestock    @relation(fields: [batchId], references: [id])
  farm          Farm     @relation(fields: [farmId], references: [id])

  @@index([userId])
  @@index([farmId])
  @@map("egg_production")
}

model Mortality {
  id          Int      @id @default(autoincrement())
  batchId     Int
  count       Int
  reason      String?
  category    String?
  subCategory String?  @map("sub_category")
  logDate     DateTime
  userId      String   @default("user_placeholder")
  farmId      Int      @default(1)
  createdAt   DateTime @default(now())
  batch       Livestock    @relation(fields: [batchId], references: [id])
  farm        Farm     @relation(fields: [farmId], references: [id])

  @@index([userId])
  @@index([farmId])
  @@map("mortality")
}

model WeightRecord {
  id            Int      @id @default(autoincrement())
  batchId       Int
  averageWeight Decimal  @db.Decimal(10, 3)
  logDate       DateTime
  userId        String   @default("user_placeholder")
  farmId        Int      @default(1)
  createdAt     DateTime @default(now())
  batch         Livestock    @relation(fields: [batchId], references: [id])
  farm          Farm     @relation(fields: [farmId], references: [id])

  @@index([userId])
  @@index([farmId])
  @@map("weight_records")
}

model Sale {
  id           Int        @id @default(autoincrement())
  customerName String?
  totalAmount  Decimal    @db.Decimal(10, 2)
  saleDate     DateTime   @default(now())
  status       String     @default("completed")
  userId       String     @default("user_placeholder")
  farmId       Int        @default(1)
  createdAt    DateTime   @default(now())
  items        SaleItem[]
  farm         Farm       @relation(fields: [farmId], references: [id])

  @@index([userId])
  @@index([farmId])
  @@map("sales")
}

model SaleItem {
  id          Int     @id @default(autoincrement())
  saleId      Int
  description String
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  totalPrice  Decimal @db.Decimal(10, 2)
  farmId      Int     @default(1)
  sale        Sale    @relation(fields: [saleId], references: [id])
  farm        Farm    @relation(fields: [farmId], references: [id])

  @@index([farmId])
  @@map("sale_items")
}

model FarmMember {
  id        Int      @id @default(autoincrement())
  farmId    Int
  userId    String
  role      Role     @default(WORKER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  farm      Farm     @relation(fields: [farmId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([farmId, userId])
  @@map("farm_members")
}

model Invitation {
  id          Int      @id @default(autoincrement())
  email       String?
  phoneNumber String?  @unique @map("phone_number")
  farmId      Int      @map("farm_id")
  role        Role     @default(WORKER)
  status      String   @default("PENDING")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  farm        Farm     @relation(fields: [farmId], references: [id])

  @@unique([email, farmId])
  @@index([farmId])
  @@map("invitations")
}

enum Role {
  OWNER
  MANAGER
  WORKER
  ACCOUNTANT
  FINANCE_OFFICER
  CASHIER
}

model VaccinationSchedule {
  id            Int      @id @default(autoincrement())
  batchId       Int
  vaccineName   String
  scheduledDate DateTime
  status        String   @default("PENDING") // PENDING, COMPLETED, SKIPPED
  notes         String?
  farmId        Int      @default(1)
  farm          Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  batch         Livestock    @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([farmId])
  @@map("vaccination_schedules")
}

model MedicationSchedule {
  id             Int      @id @default(autoincrement())
  batchId        Int
  medicationName String
  scheduledDate  DateTime
  status         String   @default("PENDING") // PENDING, COMPLETED, SKIPPED
  notes          String?
  farmId         Int      @default(1)
  farm           Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  batch          Livestock    @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([farmId])
  @@map("medication_schedules")
}

model FarmSettings {
  id                      Int      @id @default(autoincrement())
  farmId                  Int      @unique
  eggRecordReminderTime   String?  @default("18:00") // 24h format
  feedRecordReminderTime  String?  @default("18:00")
  currency                String   @default("GHS")   // Multi-currency support
  growthTargetStandard    Int?     @map("growth_target_standard") // Reference to GrowthStandards table or preference
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  farm                    Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@map("farm_settings")
}

model AuditLog {
  id            Int      @id @default(autoincrement())
  tableName     String   @map("table_name")
  recordId      Int      @map("record_id")
  attributeName String   @map("attribute_name")
  oldValue      String?  @map("old_value")
  newValue      String?  @map("new_value")
  reason        String?
  userId        String   @map("user_id")
  farmId        Int      @map("farm_id")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([farmId])
  @@index([userId])
  @@map("audit_logs")
}

model Expense {
  id          Int             @id @default(autoincrement())
  farmId      Int
  userId      String          @map("user_id")
  amount      Decimal         @db.Decimal(10, 2)
  category    ExpenseCategory
  description String?
  expenseDate DateTime        @default(now()) @map("expense_date")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  farm        Farm            @relation(fields: [farmId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id])

  @@index([farmId])
  @@index([userId])
  @@map("expenses")
}

enum ExpenseCategory {
  FEED
  MEDICATION
  EQUIPMENT
  UTILITIES
  SALARY
  MAINTENANCE
  OTHER
}

model UserPermission {
  id               Int     @id @default(autoincrement())
  userId           String  @map("user_id")
  farmId           Int     @map("farm_id")
  canViewFinance   Boolean @default(false) @map("can_view_finance")
  canEditFinance   Boolean @default(false) @map("can_edit_finance")
  canViewInventory Boolean @default(false) @map("can_view_inventory")
  canEditInventory Boolean @default(false) @map("can_edit_inventory")
  canViewBatches   Boolean @default(false) @map("can_view_batches")
  canEditBatches   Boolean @default(false) @map("can_edit_batches")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  farm Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@unique([userId, farmId])
  @@index([farmId])
  @@index([userId])
  @@map("user_permissions")
}

model GrowthStandards {
  id            Int      @id @default(autoincrement())
  livestockType LivestockType
  ageInDays     Int
  targetWeight  Decimal  @db.Decimal(10, 3)
  targetFeed    Decimal? @db.Decimal(10, 3)
  unit          String   @default("kg")
  createdAt     DateTime @default(now())

  @@map("growth_standards")
}

model SubscriptionPlan {
  id          Int              @id @default(autoincrement())
  name        String
  tier        SubscriptionTier
  price       Decimal          @db.Decimal(10, 2)
  currency    String           @default("USD")
  interval    String           @default("monthly") // monthly, yearly
  features    Json?            // Feature list/flags
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id          Int              @id @default(autoincrement())
  farmId      Int              @unique
  planId      Int
  status      String           @default("ACTIVE") // ACTIVE, CANCELLED, EXPIRED
  startDate   DateTime         @default(now())
  endDate     DateTime?
  farm        Farm             @relation(fields: [farmId], references: [id])
  plan        SubscriptionPlan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

enum SubscriptionTier {
  BASIC
  STANDARD
  PREMIUM
}

enum FeedType {
  PRE_STARTER
  STARTER
  GROWER
  FINISHER
  BREEDER
  CUSTOM
}

model Customer {
  id          Int      @id @default(autoincrement())
  farmId      Int
  name        String
  phone       String?
  email       String?
  address     String?
  balanceOwed Decimal  @default(0) @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  farm        Farm     @relation(fields: [farmId], references: [id])
  orders      Order[]

  @@map("customers")
}

model Order {
  id          Int         @id @default(autoincrement())
  farmId      Int
  customerId  Int
  totalAmount    Decimal     @db.Decimal(10, 2)
  discountAmount Decimal     @default(0) @db.Decimal(10, 2)
  currency       String      @default("USD")
  status         String      @default("PENDING") // PENDING, PAID, SHIPPED, COMPLETED, CANCELLED
  orderDate      DateTime    @default(now())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  farm           Farm        @relation(fields: [farmId], references: [id])
  customer       Customer    @relation(fields: [customerId], references: [id])
  items          OrderItem[]

  @@map("orders")
}

model OrderItem {
  id          Int     @id @default(autoincrement())
  orderId     Int
  description String
  quantity    Int
  unitPrice   Decimal    @db.Decimal(10, 2)
  totalPrice  Decimal    @db.Decimal(10, 2)
  inventoryId Int?
  livestockId Int?
  inventory   Inventory? @relation(fields: [inventoryId], references: [id])
  batch       Livestock? @relation(fields: [livestockId], references: [id])
  order       Order      @relation(fields: [orderId], references: [id])

  @@map("order_items")
}

model FeedFormulation {
  id              Int      @id @default(autoincrement())
  farmId          Int
  name            String   // Formulation Name (e.g. "Broiler Starter")
  type            FeedType // PRE_STARTER, STARTER, GROWER, FINISHER
  targetLivestock LivestockType?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  farm            Farm     @relation(fields: [farmId], references: [id])
  ingredients     FeedFormulationIngredient[]
  feedingLogs     FeedingLog[]

  @@map("feed_formulations")
}

model FeedFormulationIngredient {
  id            Int             @id @default(autoincrement())
  formulationId Int
  inventoryId   Int
  percentage    Decimal?        @db.Decimal(5, 2) // Proportion in 0.00-100.00
  quantity      Decimal?        @db.Decimal(10, 3) // Absolute amount if preferred
  unit          String?         @default("kg")
  formulation   FeedFormulation @relation(fields: [formulationId], references: [id], onDelete: Cascade)
  inventory     Inventory       @relation(fields: [inventoryId], references: [id])

  @@map("feed_formulation_ingredients")
}
